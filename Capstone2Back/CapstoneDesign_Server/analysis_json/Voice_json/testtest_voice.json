        },
        "00:02:21.00": {
            "segment_index": 18,
            "start": 141.0,
            "end": 149.0,
            "duration": 8.0,
            "text": "사용자는 실비아 루틴을 통해 본인의 기저질환에 맞는 생활 기록을 진행하여 건강한 생활습관을 형성할 수 있으며",
            "speech_rate_cps": 7.5,
            "prosody": {
                "jitter": 0.989,
                "shimmer": 8.798
