        },
        "00:00:07.00": {
            "segment_index": 1,
            "start": 7.0,
            "end": 14.0,
            "duration": 7.0,
            "text": "저는 어릴 적부터 조 부모님 손에서 자라 노인문제에 관심이 많습니다.",
            "speech_rate_cps": 5.429,
            "prosody": {
                "jitter": 0.819,
