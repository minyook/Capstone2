        "00:03:24.00": {
            "segment_index": 25,
            "start": 204.0,
            "end": 211.0,
            "duration": 7.0,
            "text": "실비아는 프린스턴드 경제학과를 졸업한 후 서울 대학교 육가대학을 휴악하고 사업을 총괄하고 있는 저와",
            "speech_rate_cps": 7.857,
            "prosody": {
                "jitter": 0.853,
                "shimmer": 10.179
