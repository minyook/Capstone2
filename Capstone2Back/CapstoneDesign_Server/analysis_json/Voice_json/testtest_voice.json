        "00:02:57.00": {
            "segment_index": 22,
            "start": 177.0,
            "end": 185.0,
            "duration": 8.0,
            "text": "저희는 매주 전라도 광주 60-70대 사용자분들을 대상으로 2시간의 사용성 평가를 진행하고 그 결과",
            "speech_rate_cps": 6.875,
