        },
        "00:04:20.00": {
            "segment_index": 31,
            "start": 260.0,
            "end": 266.0,
            "duration": 6.0,
            "text": "또한 중장기적으로 치매 전 단계 환자를 위한 디지털 치료제 시장에 진출합니다.",
            "speech_rate_cps": 7.167,
            "prosody": {
                "jitter": 0.972,
