        },
        "00:02:08.00": {
            "segment_index": 17,
            "start": 128.0,
            "end": 141.0,
            "duration": 13.0,
            "text": "실비아의 루틴은 치매 예방을 전 세계적으로 입증한 빌란드의 스터디류 기반으로 과학적으로 설계되었으며 나를 위해 찾아오는 체계적인 관리 경험을 제공합니다.",
            "speech_rate_cps": 6.538,
            "prosody": {
                "jitter": 0.96,
                "shimmer": 9.153
