        },
        "00:00:31.00": {
            "segment_index": 4,
            "start": 31.0,
            "end": 36.0,
            "duration": 5.0,
            "text": "실비아가 가장 먼저 해결하고자 하는 문제는 치매인데요.",
            "speech_rate_cps": 6.0,
            "prosody": {
                "jitter": 0.783,
                "shimmer": 10.203
