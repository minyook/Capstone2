        "00:03:05.00": {
            "segment_index": 23,
            "start": 185.0,
            "end": 194.0,
            "duration": 9.0,
            "text": "평균 접촉시간 22분, 높은 만족도를 달성하여 광주 서구청과의 업무 협약과 116가구 대상의 유료 계약을 체결했습니다.",
            "speech_rate_cps": 7.333,
