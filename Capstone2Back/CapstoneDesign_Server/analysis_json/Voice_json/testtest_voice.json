        },
        "00:01:18.00": {
            "segment_index": 11,
            "start": 78.0,
            "end": 88.0,
            "duration": 10.0,
            "text": "아쉽게도 현존하는 디지털 솔루션은 중장년의 사용성과 치매 예방을 위한 통합성 면에서 앞서 말씀드린 문제를 해결하지 못하고 있습니다.",
            "speech_rate_cps": 7.3,
            "prosody": {
                "jitter": 0.796,
                "shimmer": 9.547
