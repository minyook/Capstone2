        },
        "00:01:36.00": {
            "segment_index": 13,
            "start": 96.0,
            "end": 100.0,
            "duration": 4.0,
            "text": "매일 쉽고 즐거운 실비아를 소개합니다.",
            "speech_rate_cps": 5.25,
            "prosody": {
                "jitter": 0.968,
                "shimmer": 9.881
