        },
        "00:01:57.00": {
            "segment_index": 16,
            "start": 117.0,
            "end": 128.0,
            "duration": 11.0,
            "text": "중장년 사용자는 저희 앱에 접속하여 AI 기반 평가를 통해 자신의 인지 상태에 맞는 맞춤형 관리 루틴을 추천받습니다.",
            "speech_rate_cps": 5.909,
