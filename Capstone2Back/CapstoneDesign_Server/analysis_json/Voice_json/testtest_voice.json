        },
        "00:03:31.00": {
            "segment_index": 26,
            "start": 211.0,
            "end": 218.0,
            "duration": 7.0,
            "text": "하버드 컴퓨터공학 학사 석사를 졸업한 뒤 중국 10센트 AI 연구원을 거쳐 실비아의 기술 개발을 총괄하고 있는 전재민 님.",
            "speech_rate_cps": 9.714,
            "prosody": {
                "jitter": 0.752,
                "shimmer": 11.525
