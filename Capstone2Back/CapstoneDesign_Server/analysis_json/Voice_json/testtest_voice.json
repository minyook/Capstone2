        },
        "00:01:49.00": {
            "segment_index": 15,
            "start": 109.0,
            "end": 117.0,
            "duration": 8.0,
            "text": "실비아는 기관에게 월구독료를 받고 기관소속 중장년분들에게 비대면 서비스를 제공하여 슥을 창출하고 있는데요.",
            "speech_rate_cps": 7.375,
            "prosody": {
                "jitter": 0.861,
                "shimmer": 9.287
