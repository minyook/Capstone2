    "segments": {
        "00:00:00.00": {
            "segment_index": 0,
            "start": 0.0,
            "end": 7.0,
            "duration": 7.0,
            "text": "안녕하세요 노화가 두렵지 않은 세상을 만드는 실비아일스 대표 고명진입니다.",
            "speech_rate_cps": 5.857,
