        },
        "00:02:29.00": {
            "segment_index": 19,
            "start": 149.0,
            "end": 156.0,
            "duration": 7.0,
            "text": "본인의 부족한 인지 영역과 취향에 맞는 맞춤형 트레이닝을 진행할 수 있습니다.",
            "speech_rate_cps": 6.143,
            "prosody": {
                "jitter": 0.86,
                "shimmer": 8.99
