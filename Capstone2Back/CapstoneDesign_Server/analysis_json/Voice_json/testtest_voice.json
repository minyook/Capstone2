        },
        "00:01:28.00": {
            "segment_index": 12,
            "start": 88.0,
            "end": 96.0,
            "duration": 8.0,
            "text": "치매 예방은 무엇보다도 꾸준함이 생명에게 이를 충족할 수 있는 새로운 방식의 솔루션.",
            "speech_rate_cps": 5.875,
            "prosody": {
                "jitter": 0.886,
