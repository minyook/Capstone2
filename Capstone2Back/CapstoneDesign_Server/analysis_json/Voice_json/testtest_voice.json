        "00:02:37.00": {
            "segment_index": 20,
            "start": 157.0,
            "end": 167.0,
            "duration": 10.0,
            "text": "사용자의 관리 현황에 따라 전문가는 실비아의 점가 웹을 통해 주기적으로 사용자에게 피드백을 제공하여 관리의 지속성과 효과를 극대화합니다.",
            "speech_rate_cps": 7.6,
            "prosody": {
                "jitter": 0.901,
                "shimmer": 9.221
